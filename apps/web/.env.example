# apps/web/.env.example — copy to apps/web/.env for local dev
DATABASE_URL=postgresql://resume:resume@localhost:5432/resume_tailor?schema=public
COMPILER_URL=http://localhost:8787

# Phase 2 — AI provider selection
# AI_PROVIDER=mock          → deterministic offline mock (default, no key required)
# AI_PROVIDER=ollama        → local model via Docker (default for shared builds)
# AI_PROVIDER=anthropic     → real Claude calls (requires ANTHROPIC_API_KEY)
# AI_PROVIDER=perplexity    → Perplexity sonar models (requires PERPLEXITY_API_KEY)
AI_PROVIDER=mock

# --- anthropic ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-5

# --- ollama (local) ---
# Inside docker-compose, OLLAMA_URL=http://ollama:11434 is wired automatically.
# For host-only dev, point this at your local Ollama install.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- perplexity ---
# Get an API key at https://www.perplexity.ai/settings/api (separate from Pro UI).
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
