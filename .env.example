# =============================================================================
# Resume Tailor — environment variables
# Copy to `.env` at the repo root (loaded by docker-compose) and to
# `apps/web/.env` (loaded by Next.js / Prisma).
# =============================================================================

# Postgres
POSTGRES_USER=resume
POSTGRES_PASSWORD=resume
POSTGRES_DB=resume_tailor
POSTGRES_PORT=5432

# Prisma — used by apps/web. When running web on host machine with Postgres in
# docker-compose, use localhost. When running web inside docker-compose, use the
# service name `db`.
DATABASE_URL=postgresql://resume:resume@localhost:5432/resume_tailor?schema=public

# Compiler microservice. From the host: http://localhost:8787
# From inside docker-compose web service: http://compiler:8787
COMPILER_URL=http://localhost:8787
COMPILER_PORT=8787

# AI provider — Phase 1 is fully mocked. Leave these unset until Phase 2.
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o-mini
